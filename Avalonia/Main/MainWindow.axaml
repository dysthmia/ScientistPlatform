<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:ScientistPlatform.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="ScientistPlatform.MainWindow"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        Background="#FFFFFF"
        FontFamily="Inter"
        Title="Scientist Platform">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F8F9FA">
            <MenuItem Header="Настройки">
                <MenuItem>
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Формат хранения данных" VerticalAlignment="Center"/>
                            <ComboBox x:Name="StorageFormatComboBox"
                                      Width="100"
                                      SelectionChanged="StorageFormatComboBox_SelectionChanged"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid>
            <views:WelcomeView x:Name="WelcomePage"/>
            <views:CatalogView x:Name="CatalogPage"/>
            <Panel x:Name="ArticlePanel">
                <ContentControl x:Name="ArticleHost"/>
            </Panel>
        </Grid>
    </DockPanel>
</Window>
