<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="using:Model.Core"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
             x:Class="ScientistPlatform.Views.CitationView"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="ComboBox.formInput">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <SolidColorBrush x:Key="ComboBoxBackground">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundPressed">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundDisabled">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForeground">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundPressed">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundDisabled">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPressed">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushFocused">#4285F4</SolidColorBrush>
            </Style.Resources>
        </Style>
        <Style Selector="ComboBox.formInput:pointerover">
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        <Style Selector="ComboBox.formInput:focus">
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="TextBox.resultDisplay">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#3C4043"/>
            <Setter Property="MinHeight" Value="150"/>
        </Style>
        <Style Selector="TextBox.resultDisplay:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Background" Value="#F1F3F4"/>
        </Style>
        <Style Selector="TextBox.resultDisplay:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#34A853"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style Selector="Button.action">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3367D6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.action:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
        </Style>
        <Style Selector="Button.save">
            <Setter Property="Background" Value="#34A853"/>
        </Style>
        <Style Selector="Button.save:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E8B46"/>
        </Style>
        
        <Style Selector="Button.backButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.backButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F1F3F4"/>
            <Setter Property="Foreground" Value="#202124"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border BorderBrush="#DADCE0" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <Button Classes="backButton" Click="BackButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Width="20" Height="20" Foreground="{Binding $parent[Button].Foreground}"/>
                        <TextBlock Text="Назад к каталогу" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="0,40" Spacing="20" Width="700" HorizontalAlignment="Center">
                <TextBlock Text="Создать ссылку на статью" FontSize="32" FontWeight="Bold" Foreground="#202124" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                
                <StackPanel Spacing="0">
                    <TextBlock Text="Статья" Classes="label"/>
                    <ComboBox x:Name="ArticlesComboBox" Classes="formInput" PlaceholderText="Выберите статью из списка..." SelectionChanged="ComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="model:Article">
                                <TextBlock Text="{Binding Title}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="GenerateButton" Classes="action" Content="Сформировать ссылку" Click="GenerateButton_Click" IsEnabled="False" Margin="0,10,0,0"/>

                <StackPanel Spacing="0" Margin="0,20,0,0">
                    <TextBlock Text="Ссылка" Classes="label"/>
                    <TextBox x:Name="ResultTextBox" Classes="resultDisplay" Height="150" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True"/>
                </StackPanel>

                <Button x:Name="SaveButton" Classes="action save" Content="Сохранить в TXT" Click="SaveButton_Click" IsEnabled="False"/>
                
                <TextBlock x:Name="MessageText" FontSize="14" FontWeight="SemiBold" Foreground="#34A853" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
