<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:ScientistPlatform.Views"
             xmlns:model="using:Model.Core"
             x:Class="ScientistPlatform.Views.CatalogView"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="Button.action">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="28,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.headerAction">
            <Setter Property="Background" Value="#4285F4"/>
        </Style>
        <Style Selector="Button.headerAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3367D6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.headerAction:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
        </Style>

        <Style Selector="Button.submit">
            <Setter Property="Background" Value="#34A853"/>
        </Style>
        <Style Selector="Button.submit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E8B46"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.submit:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
        </Style>

        <Style Selector="TextBox.searchInput">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="17,8"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="23"/>
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundFocused">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForeground">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundFocused">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrush">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused">#4285F4</SolidColorBrush>
            </Style.Resources>
        </Style>

        <Style Selector="TextBox.formInput">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundFocused">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForeground">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundFocused">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused">#4285F4</SolidColorBrush>
            </Style.Resources>
        </Style>
        <Style Selector="TextBox.formInput:pointerover">
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        <Style Selector="TextBox.formInput:focus">
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="ComboBox.formInput">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <SolidColorBrush x:Key="ComboBoxBackground">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundPressed">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundDisabled">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForeground">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundPressed">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundDisabled">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPressed">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushFocused">#4285F4</SolidColorBrush>
            </Style.Resources>
        </Style>
        <Style Selector="ComboBox.formInput:pointerover">
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        <Style Selector="ComboBox.formInput:focus">
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Style.Resources>
                <SolidColorBrush x:Key="MenuFlyoutPresenterBackground">#FFFFFF</SolidColorBrush>
            </Style.Resources>
        </Style>

        <Style Selector="FlyoutPresenter">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="MinWidth" Value="320"/>
            <Style.Resources>
                <SolidColorBrush x:Key="FlyoutPresenterBackground">#FFFFFF</SolidColorBrush>
            </Style.Resources>
        </Style>

        <Style Selector="FlyoutPresenter RadioButton">
            <Setter Property="Foreground" Value="#3C4043"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,4"/>
            <Style.Resources>
                <!-- Unchecked State: Blue outline -->
                <SolidColorBrush x:Key="RadioButtonBorderBrush">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonBorderBrushPointerOver">#3367D6</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonBorderBrushPressed">#1A73E8</SolidColorBrush>
                
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStroke">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokePointerOver">#3367D6</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokePressed">#1A73E8</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokeUnchecked">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokeUncheckedPointerOver">#3367D6</SolidColorBrush>
                
                <!-- Checked State: Blue filled circle with white dot -->
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokeChecked">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseStrokeCheckedPointerOver">#3367D6</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseFillChecked">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseFillCheckedPointerOver">#3367D6</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonCheckGlyphFill">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonCheckGlyphFillPointerOver">#FFFFFF</SolidColorBrush>
                
                <SolidColorBrush x:Key="RadioButtonOuterEllipseFillUnchecked">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonOuterEllipseFillUncheckedPointerOver">#FFFFFF</SolidColorBrush>
                
                <!-- Dark text on hover/press -->
                <SolidColorBrush x:Key="RadioButtonForegroundPointerOver">#3C4043</SolidColorBrush>
                <SolidColorBrush x:Key="RadioButtonForegroundPressed">#202124</SolidColorBrush>
            </Style.Resources>
        </Style>

        <Style Selector="FlyoutPresenter RadioButton:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#3C4043"/>
        </Style>

        <Style Selector="FlyoutPresenter TextBlock.flyoutTitle">
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="FlyoutPresenter TextBlock.flyoutLabel">
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="FlyoutPresenter Button.apply">
            <Setter Property="Background" Value="#34A853"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="23"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="FlyoutPresenter Button.apply:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E8B46"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="FlyoutPresenter Button.apply:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
        </Style>

        <Style Selector="MenuItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#3C4043"/>
            <Setter Property="Padding" Value="16,10"/>
            <Style.Resources>
                <SolidColorBrush x:Key="MenuFlyoutItemForeground">#3C4043</SolidColorBrush>
                <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver">#F1F3F4</SolidColorBrush>
            </Style.Resources>
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="134,*">
        <Border BorderBrush="#DADCE0"
                BorderThickness="0,0,0,1">
            <Grid Margin="38,0,110,0"
                  ColumnDefinitions="Auto,48,Auto,14,Auto,14,*,14,Auto"
                  VerticalAlignment="Center">
                <Button Grid.Column="0" 
                        Background="Transparent" 
                        Padding="0" 
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Logo_Click">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Sci" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                        <TextBlock Text="ent" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                        <TextBlock Text="ist" FontSize="36" FontWeight="Bold" Foreground="#FBBC05"/>
                        <TextBlock Text=" " FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="Pla" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                        <TextBlock Text="tf" FontSize="36" FontWeight="Bold" Foreground="#34A853"/>
                        <TextBlock Text="orm" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                    </StackPanel>
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </Button.Styles>
                </Button>

                <Button x:Name="FilterButton" Grid.Column="2" Classes="action headerAction" Content="Фильтры">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft" VerticalOffset="12">
                            <StackPanel Spacing="0">
                                <TextBlock Text="Сортировка" Classes="flyoutTitle"/>
                                
                                <RadioButton x:Name="SortAZRadio" Content="От А до Я" IsChecked="True" GroupName="SortGroup"/>
                                <RadioButton x:Name="SortZARadio" Content="От Я до А" GroupName="SortGroup"/>
                                
                                <Separator Height="1" Background="#DADCE0" Margin="0,12"/>
                                
                                <RadioButton x:Name="SortNewestRadio" Content="Сначала новые" GroupName="SortGroup"/>
                                <RadioButton x:Name="SortOldestRadio" Content="Сначала старые" GroupName="SortGroup"/>
                                
                                <Button Content="Применить" 
                                        Classes="apply" 
                                        Click="ApplySort_Click"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <Button x:Name="CriteriaButton" Grid.Column="4" Classes="headerAction" Content="Поиск по критериям">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft" VerticalOffset="12">
                            <StackPanel Spacing="0">
                                <TextBlock Text="Поиск по критериям" Classes="flyoutTitle"/>
                                
                                <TextBlock Text="Выберите критерий" Classes="flyoutLabel"/>
                                <ComboBox x:Name="CriteriaComboBox" 
                                          Classes="formInput" 
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,16"
                                          SelectionChanged="CriteriaInputs_Changed">
                                    <ComboBoxItem Content="Название" Tag="Title"/>
                                    <ComboBoxItem Content="ISSN" Tag="ISSN"/>
                                    <ComboBoxItem Content="Ключевые слова" Tag="KeyWords"/>
                                    <ComboBoxItem Content="Тип" Tag="Type"/>
                                    <ComboBoxItem Content="Дата публикации" Tag="PublishedAt"/>
                                </ComboBox>

                                <TextBlock Text="Введите значение" Classes="flyoutLabel"/>
                                <TextBox x:Name="CriteriaValueTextBox" 
                                         Classes="formInput" 
                                         PlaceholderText="Поиск..."
                                         TextChanged="CriteriaInputs_Changed"/>

                                <Button x:Name="ApplyCriteriaButton"
                                        Content="Применить" 
                                        Classes="apply" 
                                        IsEnabled="False"
                                        Click="ApplyCriteria_Click"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <TextBox x:Name="MainSearchTextBox"
                         Grid.Column="6"
                         Classes="searchInput"
                         PlaceholderText="Поиск статей..."
                         TextChanged="MainSearchTextBox_TextChanged"
                         KeyDown="MainSearchTextBox_KeyDown"/>

                <Button x:Name="SearchButton" 
                        Grid.Column="8" 
                        Classes="action headerAction" 
                        Content="Найти статьи"
                        IsEnabled="False"
                        Click="SearchButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,400" Margin="40,40,40,0">
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="0,0,20,0">
                <ItemsControl x:Name="ArticlesList"
                              HorizontalAlignment="Stretch">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="views:ArticleListItem">
                            <Button Classes="articleItem"
                                    Margin="0,0,0,21"
                                    Click="ArticleButton_Click">
                                <Border Padding="19,17,19,17"
                                        MinHeight="128"
                                        BorderBrush="#4285F4"
                                        BorderThickness="3"
                                        CornerRadius="20"
                                        Background="#FFFFFF">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#111111"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding PublishedAt, StringFormat='Опубликовано: {0}'}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#626262"/>
                                        <TextBlock Text="{Binding Authors, StringFormat='Авторы: {0}'}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#626262"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Column="1"
                        Margin="40,0,0,40"
                        Spacing="18"
                        VerticalAlignment="Top">
                <Border Background="#FFFFFF"
                        CornerRadius="20"
                        Padding="25"
                        BorderBrush="#4285F4"
                        BorderThickness="3">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Отправить статью"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#202124"
                                   HorizontalAlignment="Left"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Издательство"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#5F6368"/>
                            <ComboBox x:Name="PublishersComboBox"
                                      Classes="formInput"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="PublisherComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:Publisher">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="ISSN статьи"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#5F6368"/>
                            <TextBox x:Name="SubmissionIssnTextBox"
                                     Classes="formInput"
                                     PlaceholderText="Напр. 1234-5678"
                                     TextChanged="SubmissionIssnTextBox_TextChanged"/>
                        </StackPanel>

                        <Button x:Name="SubmitArticleButton"
                                Classes="action submit"
                                Content="Отправить статью"
                                Click="SubmitArticleButton_Click"
                                IsEnabled="False"
                                Margin="0,5,0,0"/>

                        <TextBlock x:Name="SubmissionMessageText"
                                   Text="Ваша статья будет отправлена на проверку в выбранное издательство."
                                   FontSize="12"
                                   Foreground="#70757A"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Button Classes="action headerAction"
                        Content="Скачать статьи"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Сохранить в JSON" Click="DownloadAllJson_Click"/>
                            <MenuItem Header="Сохранить в XML" Click="DownloadAllXml_Click"/>
                            <MenuItem Header="Сохранить в TXT" Click="DownloadAllTxt_Click"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button Classes="action headerAction"
                        Content="Создать ссылку на статью"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
