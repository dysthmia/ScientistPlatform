<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ScientistPlatform.Views.ArticleView"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="Button.backButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5F6368"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.backButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F1F3F4"/>
            <Setter Property="Foreground" Value="#202124"/>
        </Style>
        
        <Style Selector="Button.export">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.export:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3367D6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3367D6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="134,*">

        <Border BorderBrush="#DADCE0" BorderThickness="0,0,0,1">
            <Grid Margin="38,0,110,0"
                  ColumnDefinitions="Auto,48,Auto,*,Auto"
                  VerticalAlignment="Center">

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sci" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="ent" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                    <TextBlock Text="ist" FontSize="36" FontWeight="Bold" Foreground="#FBBC05"/>
                    <TextBlock Text=" " FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Pla" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="tf" FontSize="36" FontWeight="Bold" Foreground="#34A853"/>
                    <TextBlock Text="orm" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Classes="backButton"
                        Click="BackButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <PathIcon Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                                  Width="20" Height="20" 
                                  Foreground="{Binding $parent[Button].Foreground}"/>
                        <TextBlock Text="Назад к каталогу" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="14">
                    <Button Classes="export"
                            Content="Скачать в JSON"
                            Click="DownloadJsonButton_Click"/>
                    <Button Classes="export"
                            Content="Скачать в XML"
                            Click="DownloadXmlButton_Click"/>
                    <Button Classes="export"
                            Content="Скачать в TXT"
                            Click="DownloadTxtButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="60,40" Spacing="20" MaxWidth="1000" HorizontalAlignment="Left">
                <SelectableTextBlock x:Name="TitleText"
                                     FontSize="32"
                                     FontWeight="Bold"
                                     TextWrapping="Wrap"
                                     Foreground="#000000"/>
                
                <StackPanel Spacing="5">
                    <SelectableTextBlock x:Name="IssnText" FontSize="20" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="TypeText" FontSize="20" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="PublishedAtText" FontSize="20" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="AuthorsText" FontSize="20" Foreground="#A0A0A0" TextWrapping="Wrap"/>
                </StackPanel>

                <SelectableTextBlock x:Name="ArticleText"
                                     FontSize="22"
                                     LineHeight="32"
                                     TextWrapping="Wrap"
                                     Margin="0,20,0,0"
                                     Foreground="#000000"/>

                <StackPanel x:Name="MethodologyPanel" Spacing="5" Margin="0,20,0,0">
                    <SelectableTextBlock Text="Методология" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="MethodologyText" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel x:Name="ResultsPanel" Spacing="5" Margin="0,10,0,0">
                    <SelectableTextBlock Text="Результаты" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="ResultsText" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel x:Name="CaseDescriptionPanel" Spacing="5" Margin="0,20,0,0">
                    <SelectableTextBlock Text="Описание случая" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="CaseDescriptionText" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel x:Name="ConclusionsPanel" Spacing="5" Margin="0,10,0,0">
                    <SelectableTextBlock Text="Заключение" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="ConclusionsText" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel x:Name="ReviewPeriodPanel" Spacing="5" Margin="0,20,0,0">
                    <SelectableTextBlock Text="Период обзора" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="ReviewPeriodText" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel x:Name="SourcesPanel" Spacing="5" Margin="0,10,0,0">
                    <SelectableTextBlock Text="Источники" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <SelectableTextBlock x:Name="SourcesText" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
