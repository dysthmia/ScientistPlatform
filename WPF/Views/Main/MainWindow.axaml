<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:WPF.Views"
        xmlns:vm="using:WPF.ViewModels"
        x:Class="WPF.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        Background="#FFFFFF"
        FontFamily="Inter"
        Title="Scientist Platform">
    <Grid>
        <views:WelcomeView IsVisible="{Binding IsWelcomeVisible}"/>
        <views:CatalogView IsVisible="{Binding IsCatalogVisible}"/>
    </Grid>
</Window>
