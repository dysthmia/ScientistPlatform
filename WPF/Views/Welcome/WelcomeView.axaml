<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WPF.ViewModels"
             x:Class="WPF.Views.WelcomeView"
             x:DataType="vm:MainWindowViewModel"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="Button.start">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="CornerRadius" Value="17"/>
            <Setter Property="Padding" Value="52,11"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.start:pointerover">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#4285F4"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
    </UserControl.Styles>

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,-42,0,0"
                Spacing="55">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <TextBlock Text="Sci" FontSize="110" FontWeight="Bold" Foreground="#4285F4"/>
            <TextBlock Text="ent" FontSize="110" FontWeight="Bold" Foreground="#EA4335"/>
            <TextBlock Text="ist" FontSize="110" FontWeight="Bold" Foreground="#FBBC05"/>
            <TextBlock Text=" " FontSize="110" FontWeight="Bold"/>
            <TextBlock Text="Pla" FontSize="110" FontWeight="Bold" Foreground="#4285F4"/>
            <TextBlock Text="tf" FontSize="110" FontWeight="Bold" Foreground="#34A853"/>
            <TextBlock Text="orm" FontSize="110" FontWeight="Bold" Foreground="#EA4335"/>
        </StackPanel>
        <Button Classes="start"
                HorizontalAlignment="Center"
                Command="{Binding StartSearchCommand}">
            <TextBlock Text="Начать поиск"
                       Foreground="{Binding $parent[Button].Foreground}"/>
        </Button>
    </StackPanel>
</UserControl>
