<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WPF.ViewModels"
             x:Class="WPF.Views.ArticleView"
             x:DataType="vm:ArticleViewModel"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#4285F4"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        
        <Style Selector="Button.export">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.export:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3367D6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3367D6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="134,*">

        <Border BorderBrush="#DADCE0" BorderThickness="0,0,0,1">
            <Grid Margin="38,0,39,0" ColumnDefinitions="Auto,48,Auto,*,Auto,14,Auto,14,Auto" VerticalAlignment="Center">

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sci" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="ent" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                    <TextBlock Text="ist" FontSize="36" FontWeight="Bold" Foreground="#FBBC05"/>
                    <TextBlock Text=" " FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Pla" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="tf" FontSize="36" FontWeight="Bold" Foreground="#34A853"/>
                    <TextBlock Text="orm" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                </StackPanel>

                <Button Grid.Column="2" Classes="nav" Content="Назад" Command="{Binding BackCommand}"/>

                <Button Grid.Column="6" Classes="export" Content="Скачать в JSON"/>
                <Button Grid.Column="8" Classes="export" Content="Скачать в XML"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="60,40" Spacing="20" MaxWidth="1000" HorizontalAlignment="Left">
                <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" TextWrapping="Wrap" Foreground="#000000"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding Type}" FontSize="20" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding PublishedAt, StringFormat='Опубликовано: {0}'}" FontSize="20" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding Authors, StringFormat='Авторы: {0}'}" FontSize="20" Foreground="#A0A0A0" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="{Binding Text}" FontSize="22" LineHeight="32" TextWrapping="Wrap" Margin="0,20,0,0" Foreground="#000000"/>

                <StackPanel IsVisible="{Binding HasMethodology}" Spacing="5" Margin="0,20,0,0">
                    <TextBlock Text="Методология" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding Methodology}" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding HasResults}" Spacing="5" Margin="0,10,0,0">
                    <TextBlock Text="Результаты" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding Results}" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding HasCaseDescription}" Spacing="5" Margin="0,20,0,0">
                    <TextBlock Text="Описание случая" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding CaseDescription}" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding HasConclusions}" Spacing="5" Margin="0,10,0,0">
                    <TextBlock Text="Заключение" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding Conclusions}" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding HasReviewPeriod}" Spacing="5" Margin="0,20,0,0">
                    <TextBlock Text="Период обзора" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding ReviewPeriod}" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding HasSources}" Spacing="5" Margin="0,10,0,0">
                    <TextBlock Text="Источники" FontSize="24" FontWeight="Bold" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding Sources}" FontSize="22" TextWrapping="Wrap" Foreground="#000000"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
