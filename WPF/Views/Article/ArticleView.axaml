<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WPF.ViewModels"
             x:Class="WPF.Views.ArticleView"
             x:DataType="vm:ArticleViewModel"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="17"/>
            <Setter Property="Padding" Value="24,6"/>
            <Setter Property="Foreground" Value="#4285F4"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        
        <Style Selector="Button.export">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="17"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.export:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3367D6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3367D6"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="100,*">

        <Border BorderBrush="#DADCE0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0" ColumnDefinitions="Auto,40,Auto,*,Auto,10,Auto,10,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Sci" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="ent" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                    <TextBlock Text="ist" FontSize="36" FontWeight="Bold" Foreground="#FBBC05"/>
                    <TextBlock Text=" " FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Pla" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="tf" FontSize="36" FontWeight="Bold" Foreground="#34A853"/>
                    <TextBlock Text="orm" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                </StackPanel>

                <Button Grid.Column="2" Classes="nav" Content="назад" Command="{Binding BackCommand}"/>

                <Button Grid.Column="4" Classes="export" Content="скачать txt"/>
                <Button Grid.Column="6" Classes="export" Content="скачать json"/>
                <Button Grid.Column="8" Classes="export" Content="скачать xml"/>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="60,40" Spacing="20" MaxWidth="1000" HorizontalAlignment="Left">
                <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" TextWrapping="Wrap" Foreground="#000000"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding Type}" FontSize="20" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding PublishedAt, StringFormat='Опубликовано: {0}'}" FontSize="20" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding Authors, StringFormat='Авторы: {0}'}" FontSize="20" Foreground="#A0A0A0" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="{Binding Text}" FontSize="22" LineHeight="32" TextWrapping="Wrap" Margin="0,20,0,0" Foreground="#000000"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
