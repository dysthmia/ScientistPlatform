<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ScientistPlatform"
             xmlns:views="using:ScientistPlatform.Views"
             x:Class="ScientistPlatform.Views.CatalogView"
             x:DataType="views:CatalogView"
             Background="#FFFFFF">
    <UserControl.Styles>
        <Style Selector="TextBox.searchInput">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="17,8"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="23"/>
        </Style>
        <Style Selector="TextBox.searchInput:focus">
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>

        <Style Selector="Button.headerAction">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="28,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.headerAction:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3367D6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        
        <Style Selector="Button.articleItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.articleItem:pointerover Border">
            <Setter Property="Background" Value="#F8F9FA"/>
        </Style>

        <Style Selector="Button.submit">
            <Setter Property="Background" Value="#34A853"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="28,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.submit:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E8B46"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.submit:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
        </Style>

        <Style Selector="TextBox.formInput">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Style.Resources>
                <SolidColorBrush x:Key="TextControlBackground">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBackgroundFocused">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForeground">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlForegroundFocused">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused">#4285F4</SolidColorBrush>
            </Style.Resources>
        </Style>
        <Style Selector="TextBox.formInput:pointerover">
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        <Style Selector="TextBox.formInput:focus">
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="ComboBox.formInput">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#202124"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <SolidColorBrush x:Key="ComboBoxBackground">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundPressed">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBackgroundDisabled">#FFFFFF</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForeground">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundPointerOver">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundPressed">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxForegroundDisabled">#202124</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushPressed">#4285F4</SolidColorBrush>
                <SolidColorBrush x:Key="ComboBoxBorderBrushFocused">#4285F4</SolidColorBrush>
            </Style.Resources>
        </Style>
        <Style Selector="ComboBox.formInput:pointerover">
            <Setter Property="BorderBrush" Value="#4285F4"/>
        </Style>
        <Style Selector="ComboBox.formInput:focus">
            <Setter Property="BorderBrush" Value="#4285F4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="134,*">
        <Border BorderBrush="#DADCE0"
                BorderThickness="0,0,0,1">
            <Grid Margin="38,0,39,0"
                  ColumnDefinitions="Auto,48,Auto,14,*,14,Auto,14,Auto,14,Auto"
                  VerticalAlignment="Center">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Sci" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="ent" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                    <TextBlock Text="ist" FontSize="36" FontWeight="Bold" Foreground="#FBBC05"/>
                    <TextBlock Text=" " FontSize="36" FontWeight="Bold"/>
                    <TextBlock Text="Pla" FontSize="36" FontWeight="Bold" Foreground="#4285F4"/>
                    <TextBlock Text="tf" FontSize="36" FontWeight="Bold" Foreground="#34A853"/>
                    <TextBlock Text="orm" FontSize="36" FontWeight="Bold" Foreground="#EA4335"/>
                </StackPanel>

                <Button Grid.Column="2" Classes="headerAction" Content="Фильтры"/>

                <TextBox Grid.Column="4"
                         Classes="searchInput"
                         PlaceholderText="Поиск статей...">
                    <TextBox.Resources>
                        <SolidColorBrush x:Key="TextControlBackground">#FFFFFF</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver">#FFFFFF</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlBackgroundFocused">#FFFFFF</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlForeground">#202124</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlForegroundPointerOver">#202124</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlForegroundFocused">#202124</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlBorderBrush">#4285F4</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver">#4285F4</SolidColorBrush>
                        <SolidColorBrush x:Key="TextControlBorderBrushFocused">#4285F4</SolidColorBrush>
                    </TextBox.Resources>
                </TextBox>

                <Button Grid.Column="6" Classes="headerAction" Content="Поиск"/>

                <Button Grid.Column="8" Classes="headerAction" Content="Скачать статьи"/>
                <Button Grid.Column="10" Classes="headerAction" Content="Создать ссылку на статью"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,400" Margin="40,40,40,0">
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          Padding="0,0,20,0">
                <ItemsControl ItemsSource="{Binding Articles}"
                              HorizontalAlignment="Stretch">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:ArticleListItem">
                            <Button Classes="articleItem" Command="{Binding OpenCommand}" Margin="0,0,0,21">
                                <Border Padding="19,17,19,17"
                                        MinHeight="128"
                                        BorderBrush="#4285F4"
                                        BorderThickness="3"
                                        CornerRadius="20"
                                        Background="#FFFFFF">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#111111"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding PublishedAt, StringFormat='Опубликовано: {0}'}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#626262"/>
                                        <TextBlock Text="{Binding Authors, StringFormat='Авторы: {0}'}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#626262"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Column="1" 
                    Background="#FFFFFF" 
                    Margin="40,0,0,40"
                    CornerRadius="20" 
                    Padding="25"
                    BorderBrush="#4285F4"
                    BorderThickness="3"
                    VerticalAlignment="Top">
                <StackPanel Spacing="20">
                    <TextBlock Text="Отправить статью" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#202124"
                               HorizontalAlignment="Left"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Издательство" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#5F6368"/>
                        <ComboBox ItemsSource="{Binding Publishers}" 
                                  SelectedItem="{Binding SelectedPublisher}"
                                  Classes="formInput"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="ISSN статьи" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#5F6368"/>
                        <TextBox Text="{Binding SubmissionIssn}" 
                                 Classes="formInput"
                                 PlaceholderText="Напр. 1234-5678"/>
                    </StackPanel>

                    <Button Classes="submit" 
                            Content="Отправить статью"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding SubmitArticleCommand}"
                            Margin="0,5,0,0"/>

                    <TextBlock Text="{Binding SubmissionMessage}"
                               FontSize="12"
                               Foreground="{Binding MessageForeground}"
                               TextWrapping="Wrap"
                               TextAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
