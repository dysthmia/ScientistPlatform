<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:ScientistPlatform.Views"
        xmlns:local="using:ScientistPlatform"
        xmlns:model="using:Model.Core"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="ScientistPlatform.MainWindow"
        x:DataType="local:MainWindow"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        Background="#FFFFFF"
        FontFamily="Inter"
        Title="Scientist Platform">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#F8F9FA">
            <MenuItem Header="Настройки">
                <MenuItem>
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Формат сохранения" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AvailableFormats}" 
                                      SelectedItem="{Binding SelectedFormat}"
                                      Width="100">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:StorageFormat">
                                        <TextBlock Text="{Binding}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>
        </Menu>
        
        <Grid>
            <views:WelcomeView IsVisible="{Binding IsWelcomeVisible}"/>
            <views:CatalogView x:Name="CatalogPage" IsVisible="{Binding IsCatalogVisible}"/>
            <Panel IsVisible="{Binding IsArticleVisible}">
                <ContentControl Content="{Binding ArticlePage}"/>
            </Panel>
        </Grid>
    </DockPanel>
</Window>
