<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:ScientistPlatform.Views"
        xmlns:local="using:ScientistPlatform"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ScientistPlatform.MainWindow"
        x:DataType="local:MainWindow"
        Width="1200"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        Background="#FFFFFF"
        FontFamily="Inter"
        Title="Scientist Platform">
    <Grid>
        <views:WelcomeView IsVisible="{Binding IsWelcomeVisible}"/>
        <views:CatalogView IsVisible="{Binding IsCatalogVisible}"/>
        <Panel IsVisible="{Binding IsArticleVisible}">
            <ContentControl Content="{Binding ArticlePage}"/>
        </Panel>
    </Grid>
</Window>
